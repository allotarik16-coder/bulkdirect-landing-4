<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BulkDirect — Scrape–Sort–Publish Automation</title>
<meta name="description" content="Automatisation Scrape–Sort–Publish. Reddit + Dropshipping. 4 agents IA qui travaillent pendant que vous dormez.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================
   BULKDIRECT v6 — Design système du dashboard
   Noir profond + cyan électrique + gradient
   bleu→violet. Tout en mono, cartes bordées.
   ============================================ */
:root{
  --fond:#050505;
  --panneau:#0B0F14;          /* cartes */
  --bordure:#3B4654;          /* bordures slate */
  --bordure-active:#22D3EE;   /* bordure carte active */
  --texte:#F2F2F0;
  --gris:#9CA3AF;
  --gris-2:#5B6470;
  --cyan:#22D3EE;             /* accent principal */
  --cyan-dim:rgba(34,211,238,.08);
  --grad-a:#4F46E5;           /* violet du logo */
  --grad-b:#22D3EE;           /* cyan du logo */
  --mono:'IBM Plex Mono',monospace;
  --titre:'Space Grotesk',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--fond);
  color:var(--texte);
  font-family:var(--mono);
  font-size:15px;line-height:1.65;
  -webkit-font-smoothing:antialiased;
  /* Texture diagonale subtile */
  background-image:repeating-linear-gradient(
    -45deg,
    transparent 0 22px,
    rgba(34,211,238,.018) 22px 23px
  );
}
::selection{background:var(--cyan);color:var(--fond)}
a{color:inherit}
:focus-visible{outline:2px solid var(--cyan);outline-offset:3px}
.conteneur{max-width:1100px;margin:0 auto;padding:0 22px}

/* ---------- Navigation ---------- */
.nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 22px;max-width:1100px;margin:0 auto;
}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none}
.puce{
  width:38px;height:38px;border-radius:10px;
  background:linear-gradient(135deg,var(--grad-a),var(--grad-b));
  display:grid;place-items:center;flex-shrink:0;
}
.puce svg{width:20px;height:20px}
.nav-nom{font-family:var(--titre);font-weight:700;font-size:19px;letter-spacing:.02em}
.nav-cta{
  text-decoration:none;font-size:13px;font-weight:600;
  color:var(--fond);background:var(--cyan);padding:9px 18px;border-radius:6px;
}

/* ---------- Hero ---------- */
.hero{padding:64px 0 48px}
.hero-tete{display:flex;gap:20px;align-items:flex-start}
.hero .puce{width:64px;height:64px;border-radius:16px}
.hero .puce svg{width:32px;height:32px}
.hero h1{
  font-family:var(--titre);font-weight:700;
  font-size:clamp(42px,8vw,72px);
  line-height:1;letter-spacing:.01em;
}
.hero-tagline{
  color:var(--gris);font-size:clamp(15px,2.6vw,19px);
  margin-top:14px;max-width:34ch;
}
.hero-stats{
  display:grid;grid-template-columns:repeat(3,auto);
  gap:36px;margin-top:36px;color:var(--cyan);
  font-size:14px;font-weight:500;
}
.hero-stats b{font-weight:600;display:block}
@media(max-width:640px){
  .hero-stats{grid-template-columns:1fr 1fr;gap:20px}
  .hero-tete{flex-direction:column}
}
.hero-actions{margin-top:40px;display:flex;gap:18px;align-items:center;flex-wrap:wrap}
.btn{
  text-decoration:none;font-weight:600;font-size:14px;
  padding:14px 28px;border-radius:8px;display:inline-block;
  transition:transform .15s;
}
.btn:hover{transform:translateY(-2px)}
.btn-cyan{background:var(--cyan);color:var(--fond)}
.btn-ligne{border:1px solid var(--bordure);color:var(--texte)}

/* ---------- Onglets ---------- */
.onglets{
  display:flex;gap:8px;
  border-top:1px solid var(--bordure);border-bottom:1px solid var(--bordure);
  margin-top:56px;
  font-size:13px;letter-spacing:.16em;text-transform:uppercase;font-weight:600;
  overflow-x:auto;
}
.onglet{
  background:none;border:none;cursor:pointer;
  font:inherit;color:var(--gris-2);
  padding:18px 22px;position:relative;white-space:nowrap;
}
.onglet[aria-selected="true"]{color:var(--cyan)}
.onglet[aria-selected="true"]::after{
  content:"";position:absolute;left:18px;right:18px;bottom:-1px;
  height:2px;background:var(--cyan);
}

/* ---------- Panneaux d'onglets ---------- */
.panneau-onglet{display:none;padding:48px 0}
.panneau-onglet.actif{display:block}

/* ---------- Cartes stack ---------- */
.cartes{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
@media(max-width:780px){.cartes{grid-template-columns:1fr}}
.carte{
  background:var(--panneau);
  border:1px solid var(--bordure);border-radius:10px;
  padding:30px 24px;text-align:center;
  transition:border-color .2s;
}
.carte:hover{border-color:var(--gris)}
.carte.active{border-color:var(--bordure-active);box-shadow:0 0 24px rgba(34,211,238,.10)}
.carte h3{
  font-size:19px;font-weight:700;line-height:1.3;margin-bottom:10px;
}
.carte p{color:var(--gris);font-size:13px}
.carte .badge{
  display:inline-block;margin-top:16px;font-size:11px;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--cyan);background:var(--cyan-dim);
  padding:5px 12px;border-radius:4px;
}

/* ---------- Pipeline ---------- */
.flux{display:grid;gap:14px;max-width:680px}
.flux-etape{
  background:var(--panneau);border:1px solid var(--bordure);border-radius:10px;
  padding:22px 24px;display:flex;gap:18px;align-items:flex-start;
}
.flux-num{
  font-weight:700;color:var(--cyan);font-size:14px;flex-shrink:0;
  width:34px;height:34px;border:1px solid var(--bordure);border-radius:8px;
  display:grid;place-items:center;
}
.flux-etape h4{font-size:15px;font-weight:700;margin-bottom:4px}
.flux-etape p{color:var(--gris);font-size:13px}

/* ---------- Inventory : signaux ---------- */
.lignes-signaux{display:grid;gap:12px}
.ligne-signal{
  background:var(--panneau);border:1px solid var(--bordure);border-radius:10px;
  padding:18px 22px;font-size:13px;
  display:flex;justify-content:space-between;gap:16px;align-items:center;flex-wrap:wrap;
}
.ligne-signal .src{color:var(--gris-2);font-size:11px}
.ligne-signal .txt{color:var(--texte);flex:1;min-width:200px}
.ligne-signal .tag{
  color:var(--cyan);background:var(--cyan-dim);
  font-size:11px;letter-spacing:.08em;text-transform:uppercase;
  padding:4px 10px;border-radius:4px;white-space:nowrap;
}

/* ---------- Tarifs ---------- */
.section{padding:72px 0}
.section h2{
  font-family:var(--titre);font-weight:700;
  font-size:clamp(30px,5vw,46px);margin-bottom:10px;
}
.section .intro{color:var(--gris);margin-bottom:44px;max-width:52ch}
.tarifs{display:grid;grid-template-columns:1fr 1fr;gap:18px;max-width:760px}
@media(max-width:680px){.tarifs{grid-template-columns:1fr}}
.plan{
  background:var(--panneau);border:1px solid var(--bordure);border-radius:12px;
  padding:34px 28px;
}
.plan.pro{border-color:var(--bordure-active);box-shadow:0 0 30px rgba(34,211,238,.08)}
.plan-nom{
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--gris-2);margin-bottom:14px;font-weight:600;
}
.plan.pro .plan-nom{color:var(--cyan)}
.plan-prix{font-family:var(--titre);font-weight:700;font-size:46px;line-height:1}
.plan-prix small{font-family:var(--mono);font-size:13px;color:var(--gris-2);font-weight:400}
.plan ul{list-style:none;margin:24px 0 30px;font-size:13px;color:var(--gris)}
.plan li{padding:8px 0;border-bottom:1px solid rgba(59,70,84,.4)}
.plan li::before{content:"▸ ";color:var(--cyan)}
.plan .btn{width:100%;text-align:center}

/* ---------- CTA final + pied ---------- */
.final{
  text-align:center;padding:96px 22px;
  border-top:1px solid var(--bordure);
}
.final h2{
  font-family:var(--titre);font-weight:700;
  font-size:clamp(30px,5.5vw,54px);line-height:1.1;margin-bottom:16px;
}
.final p{color:var(--gris);margin-bottom:34px}
.pied{
  border-top:1px solid var(--bordure);padding:26px 22px;
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;
  font-size:12px;color:var(--gris-2);max-width:1100px;margin:0 auto;
}
@media(prefers-reduced-motion:reduce){
  .btn:hover{transform:none}
}
</style>
</head>
<body>

<nav class="nav">
  <a class="nav-logo" href="#">
    <span class="puce" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="#050505" stroke-width="2">
        <rect x="7" y="7" width="10" height="10" rx="1.5"/>
        <rect x="10" y="10" width="4" height="4"/>
        <path d="M9 4v3M15 4v3M9 17v3M15 17v3M4 9h3M4 15h3M17 9h3M17 15h3"/>
      </svg>
    </span>
    <span class="nav-nom">BulkDirect</span>
  </a>
  <a class="nav-cta" href="#tarifs">Démarrer</a>
</nav>

<!-- ===== HERO ===== -->
<header class="hero conteneur">
  <div class="hero-tete">
    <span class="puce" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="#050505" stroke-width="2">
        <rect x="7" y="7" width="10" height="10" rx="1.5"/>
        <rect x="10" y="10" width="4" height="4"/>
        <path d="M9 4v3M15 4v3M9 17v3M15 17v3M4 9h3M4 15h3M17 9h3M17 15h3"/>
      </svg>
    </span>
    <div>
      <h1>BULKDIRECT</h1>
      <p class="hero-tagline">Scrape–Sort–Publish Automation • Reddit + Dropshipping</p>
    </div>
  </div>

  <div class="hero-stats">
    <div><span>Produits scrapés :</span><b>2,4 K</b></div>
    <div><span>Publiés aujourd'hui :</span><b>87</b></div>
    <div><span>Revenus (30 j) :</span><b>3 200 $</b></div>
  </div>

  <div class="hero-actions">
    <a class="btn btn-cyan" href="#tarifs">Lancer l'automatisation</a>
    <a class="btn btn-ligne" href="#apercu">Voir le pipeline</a>
  </div>

  <!-- ===== Onglets ===== -->
  <div class="onglets" role="tablist" id="apercu">
    <button class="onglet" role="tab" aria-selected="true" data-cible="t-overview">Overview</button>
    <button class="onglet" role="tab" aria-selected="false" data-cible="t-pipeline">Pipeline</button>
    <button class="onglet" role="tab" aria-selected="false" data-cible="t-inventory">Inventory</button>
  </div>

  <!-- Onglet 1 : Overview -->
  <div class="panneau-onglet actif" id="t-overview" role="tabpanel">
    <div class="cartes">
      <div class="carte active">
        <h3>Reddit Scraper</h3>
        <p>11 subreddits surveillés en continu</p>
        <span class="badge">Actif</span>
      </div>
      <div class="carte">
        <h3>Claude Batch API</h3>
        <p>Classification automatique des produits</p>
        <span class="badge">Classification</span>
      </div>
      <div class="carte">
        <h3>Supabase Database</h3>
        <p>Stockage structuré, prêt à publier</p>
        <span class="badge">PostgreSQL</span>
      </div>
    </div>
  </div>

  <!-- Onglet 2 : Pipeline -->
  <div class="panneau-onglet" id="t-pipeline" role="tabpanel">
    <div class="flux">
      <div class="flux-etape">
        <span class="flux-num">01</span>
        <div><h4>Planificateur</h4><p>Cible les subreddits et mots-clés du marché. Construit le plan de scan du cycle.</p></div>
      </div>
      <div class="flux-etape">
        <span class="flux-num">02</span>
        <div><h4>Exécuteur Reddit</h4><p>Scanne les threads, récupère posts et commentaires, filtre le bruit en amont.</p></div>
      </div>
      <div class="flux-etape">
        <span class="flux-num">03</span>
        <div><h4>Ingénieur Pipeline</h4><p>Qualifie chaque thread : produit gagnant, intention d'achat, tendance émergente.</p></div>
      </div>
      <div class="flux-etape">
        <span class="flux-num">04</span>
        <div><h4>QA Reviewer</h4><p>Note chaque signal, rejette les faux positifs. Seul le validé entre en base.</p></div>
      </div>
    </div>
  </div>

  <!-- Onglet 3 : Inventory -->
  <div class="panneau-onglet" id="t-inventory" role="tabpanel">
    <div class="lignes-signaux">
      <div class="ligne-signal">
        <span class="src">r/SaaS · 2 h</span>
        <span class="txt">« Cherche un outil feedback clients, budget 100 €/mois »</span>
        <span class="tag">Intention d'achat</span>
      </div>
      <div class="ligne-signal">
        <span class="src">r/dropship · 4 h</span>
        <span class="txt">« Ce gadget explose en ce moment, +300 % de mentions »</span>
        <span class="tag">Produit gagnant</span>
      </div>
      <div class="ligne-signal">
        <span class="src">r/Entrepreneur · 7 h</span>
        <span class="txt">« On quitte [concurrent], support catastrophique »</span>
        <span class="tag">Churn concurrent</span>
      </div>
    </div>
  </div>
</header>

<!-- ===== Tarifs ===== -->
<section class="section conteneur" id="tarifs">
  <h2>Tarifs</h2>
  <p class="intro">Sans engagement. Votre stack tourne dès la première heure.</p>
  <div class="tarifs">
    <div class="plan">
      <p class="plan-nom">Starter</p>
      <p class="plan-prix">29 €<small> / mois</small></p>
      <ul>
        <li>5 subreddits surveillés</li>
        <li>1 cycle de scan / jour</li>
        <li>Signaux livrés par email</li>
        <li>Historique 30 jours</li>
      </ul>
      <a class="btn btn-ligne" href="#">Choisir Starter</a>
    </div>
    <div class="plan pro">
      <p class="plan-nom">Pro</p>
      <p class="plan-prix">99 €<small> / mois</small></p>
      <ul>
        <li>Subreddits illimités</li>
        <li>Scans en continu (24/7)</li>
        <li>CRM intégré + export</li>
        <li>Alertes temps réel</li>
        <li>Historique illimité</li>
      </ul>
      <a class="btn btn-cyan" href="#">Choisir Pro</a>
    </div>
  </div>
</section>

<!-- ===== CTA final ===== -->
<section class="final">
  <h2>Scrape. Sort. Publish.<br>Pendant que vous dormez.</h2>
  <p>Premier cycle lancé en moins de 5 minutes.</p>
  <a class="btn btn-cyan" href="#tarifs">Lancer l'automatisation</a>
</section>

<footer class="pied">
  <span>© 2026 BulkDirect — Marseille</span>
  <span>contact@bulkdirect.io</span>
</footer>

<script>
/* Onglets : bascule simple */
document.querySelectorAll('.onglet').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.onglet').forEach(b => b.setAttribute('aria-selected','false'));
    document.querySelectorAll('.panneau-onglet').forEach(p => p.classList.remove('actif'));
    btn.setAttribute('aria-selected','true');
    document.getElementById(btn.dataset.cible).classList.add('actif');
  });
});
</script>
</body>
</html>
